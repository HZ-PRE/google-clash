{
  "manifest_version": 3,
  "name": "块垒加速器",
  "version": "1.0.0",
  "key": "",
  "description": "Clash/Mihomo代理控制器。支持一键启动Mihomo、浏览器代理切换及Clash分组节点选择。",
  "permissions": [
    "proxy",
    "storage",
    "alarms",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://[::1]/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "块垒加速器",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
