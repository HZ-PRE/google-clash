{
  "manifest_version": 3,
  "name": "Clash Switchboard",
  "version": "1.0.0",
  "key": "",
  "description": "Chrome proxy controller for Clash / Clash.Meta / Mihomo. Supports one-click Mihomo startup, browser proxy switching and Clash group node selection.",
  "permissions": [
    "proxy",
    "storage",
    "alarms",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://[::1]/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Clash Switchboard",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
